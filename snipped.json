	"8_Bigmod": {
	"prefix": "bigmod",
	"body": [
		"int bigmod(int a, int b, int M)",
		"{",
		"    if(b == 0) return 1 % M;",
		"    int x = bigmod(a, b / 2, M);",
		"    x = (x * x) % M;",
		"    if(b % 2 == 1) x = (x * a) % M;",
		"    return x;",
		"}"
	],
	"description": ""
	},

