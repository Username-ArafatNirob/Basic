	"5_mergesort": {
	"prefix": "mergesort",
	"body": [
		"void merge(vector<int>& a, int l, int mid, int r) {",
		"    int p = l;",
		"    int q = mid + 1;",
		"",
		"    int len = r - l + 1;",
		"    vector<int> v(len);",
		"    int k = 0;",
		"",
		"    for (int i = l; i <= r; i++) {",
		"        if (p > mid) {",
		"            v[k] = a[q];",
		"            k++, q++;",
		"        }",
		"        else if (q > r) {",
		"            v[k] = a[p];",
		"            k++, p++;",
		"        }",
		"        else if (a[p] <= a[q]) {",
		"            v[k] = a[p];",
		"            k++, p++;",
		"        }",
		"        else {",
		"            v[k] = a[q];",
		"            k++, q++;",
		"        }",
		"    }",
		"",
		"    k = 0;",
		"    for (int i = l; i <= r; i++) {",
		"        a[i] = v[k];",
		"        k++;",
		"    }",
		"}",
		"",
		"void mergeSort(vector<int>& a, int l, int r) {",
		"    if (l >= r) return;",
		"    int mid = (l + r) / 2;",
		"",
		"    mergeSort(a, l, mid);",
		"    mergeSort(a, mid + 1, r);   ",
		"    merge(a, l, mid, r);        ",
		"}"
	],
	"description": ""
	},

	"6_prime_factorization": {
  	"prefix": "primefactor",
  	"body": [
		"vector<int> primeFactor (int n)",
		"{",
		"    vector<int> factors;",
		"    for(auto p : primes){",
		"        if(1LL*p*p > n) break;",
		"",
		"        if(n % p == 0){",
		"            while(n % p == 0){",
		"                factors.push_back(p);",
		"                n/=p;",
		"            }",
		"        }",
		"    }",
		"",
		"    if( n > 1){",
		"        factors.push_back(n);",
		"    }",
		"    return factors;",
		"}"
  ],
	"description": ""
	},

	"7_number_of_divisor_prmfact": {
	"prefix": "NOD",
	"body": [
		"int NOD ( ll n )",
		"{",
		"    int nod = 1;",
		"",
		"    for ( auto p : primes ) {",
		"        if ( 1LL * p * p > n ) break;",
		"",
		"        if ( n % p == 0 ) {",
		"            int cnt = 0;",
		"",
		"            while ( n % p == 0 ) {",
		"                n /= p;",
		"                cnt++;",
		"            }",
		"",
		"            cnt++;",
		"            nod *= cnt;",
		"        }",
		"    }",
		"",
		"    if ( n > 1 ) {",
		"        nod *= 2;",
		"    }",
		"",
		"    return nod;",
		"}"
	],
	"description": ""
