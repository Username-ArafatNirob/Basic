		"ll powr(ll a, ll b){",
		"    ll ans = 1;",
		"    while(b > 0){",
		"        if(b & 1){",
		"            ans *= a;",
		"            b--;",
		"        }",
		"        else{",
		"            b /= 2;",
		"            a *= a;",
		"        }",
		"    }",
